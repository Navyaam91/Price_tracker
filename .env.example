# --- BACKEND (Django) ---
# A secret key for production (random string)
SECRET_KEY=your-django-secret-key-here

# Set to False in production
DEBUG=True

# Backend URL (e.g. https://your-backend.onrender.com)
# Separated by commas
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# PostgreSQL Database URL (provided by Render)
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://postgres:postgres@localhost:5432/price_tracker

# Frontend URL for CORS (e.g. https://your-frontend.onrender.com)
FRONTEND_URL=http://localhost:5173

# Email Credentials (for price alerts)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here


# --- FRONTEND (Vite) ---
# Your Backend URL
VITE_API_URL=http://127.0.0.1:8000
